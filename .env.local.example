# Required for Keystatic CMS (GitHub login)
# Create a GitHub OAuth App at: https://github.com/settings/developers
# App name: Leo Falkovsky CMS
# Homepage URL: https://leofalkovsky.ca
# Authorization callback URL: https://leofalkovsky.ca/api/keystatic/github/oauth/callback

KEYSTATIC_GITHUB_CLIENT_ID=your_client_id_here
KEYSTATIC_GITHUB_CLIENT_SECRET=your_client_secret_here

# Generate a random secret (e.g. run: openssl rand -hex 32)
KEYSTATIC_SECRET=your_random_secret_here
